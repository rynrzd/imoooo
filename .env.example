# =============================================================
# ImmoPilot — copiez ce fichier vers .env.local et renseignez vos valeurs.
# .env.local n'est jamais commité.
# =============================================================

# ---------- Supabase (Projet → Settings → API Keys) ----------

# URL du projet, SANS chemin (/rest/v1, /auth/v1… sont interdits ici)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé « publishable » uniquement (sb_publishable_…)
# ⚠️ JAMAIS de clé secrète (sb_secret_…) ni de service_role ici.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_votre-cle-fictive

# Clé secrète du projet (sb_secret_…) — SERVEUR UNIQUEMENT.
# Requise par le webhook Stripe pour écrire la table subscriptions.
# Jamais préfixée NEXT_PUBLIC_, jamais exposée au navigateur.
SUPABASE_SECRET_KEY=sb_secret_votre-cle-fictive

# URL du site (redirections des e-mails d'authentification et de Stripe)
# OBLIGATOIRE en production Vercel : le build échoue si elle manque.
# ⚠️ https://immopilot-silk.vercel.app n'est PAS accessible depuis un téléphone : pour un
# test mobile, utilisez une URL de preview Vercel (voir AUTH_SETUP.md).
NEXT_PUBLIC_SITE_URL=https://immopilot-silk.vercel.app

# Mode démo (données fictives, AUCUNE authentification). Sans les variables
# Supabase, le démarrage ÉCHOUE sauf si cette variable vaut explicitement true.
# Ne jamais activer en production.
NEXT_PUBLIC_DEMO_MODE=false

# Environnement applicatif affiché/loggué (development | production)
NEXT_PUBLIC_APP_ENV=production

# ---------- Stripe (Dashboard → Developers → API keys) ----------
# Tant que ces variables sont vides, l'application fonctionne normalement
# et affiche « paiement bientôt disponible » sur la page Abonnement.

# Clé secrète (sk_test_… en test, sk_live_… en production) — SERVEUR UNIQUEMENT.
STRIPE_SECRET_KEY=

# Clé publiable (pk_test_… / pk_live_…) — la seule exposable au navigateur.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Secret de signature du webhook (whsec_…) — Dashboard → Developers → Webhooks.
# Endpoint à créer : https://votre-domaine.fr/api/stripe/webhook
# Événements : checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# Identifiants de prix (price_…) des produits à créer dans Stripe.
# Abonnements mensuels récurrents (source des plans : src/config/plans.ts) :
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
# Offre Fondateur — paiements UNIQUES (one-time) :
# palier 1 = places 1-50 (299 €), palier 2 = places 51-100 (499 €).
STRIPE_PRICE_FOUNDER_T1=
STRIPE_PRICE_FOUNDER_T2=

# ---------- E-mails (optionnel — aucun envoi tant que vide) ----------
# Voir docs/EMAILS.md pour la configuration complète (domaine, DNS, SMTP
# Supabase Auth). Fournisseur recommandé : Resend.
# EMAIL_PROVIDER : resend | brevo | postmark
EMAIL_PROVIDER=resend

# Expéditeur : nom affiché + adresse (le domaine doit être vérifié chez le
# fournisseur). En développement Resend sans domaine vérifié, utilisez
# onboarding@resend.dev (envoi vers votre propre adresse uniquement).
EMAIL_FROM_NAME=ImmoPilot
EMAIL_FROM_ADDRESS=

# (Compatibilité : EMAIL_FROM « Nom <adresse@domaine.fr> » reste accepté
# si EMAIL_FROM_ADDRESS est vide.)
EMAIL_FROM=

# Boîte qui reçoit les messages du formulaire de contact.
SUPPORT_EMAIL=

# Clé API du fournisseur choisi — SERVEUR UNIQUEMENT, jamais NEXT_PUBLIC_.
RESEND_API_KEY=
BREVO_API_KEY=
POSTMARK_SERVER_TOKEN=

# Secret du planificateur (relances automatiques /api/cron/rent-reminders).
# Sans lui, les relances automatiques restent inactives.
CRON_SECRET=
